# Copy to .env and fill in.

# Environment: "local" (Ollama + FAISS + SQLite) or "databricks"
ENVIRONMENT=local

# Databricks (required when ENVIRONMENT=databricks)
DATABRICKS_HOST=
DATABRICKS_TOKEN=
DATABRICKS_WAREHOUSE_PATH=
DATABRICKS_CATALOG=defpredict
DATABRICKS_SCHEMA=default

# LLM (Ollama locally, Databricks Model Serving in prod — both OpenAI-compatible)
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=mistral:7b-instruct
LLM_TEMPERATURE=0.1

# Fine-tuned endpoints (leave empty to fall back to base model)
SUGGESTOR_MODEL=
EVALUATOR_MODEL=

# Embedding model (downloaded to HF cache on first use)
EMBEDDING_MODEL=BAAI/bge-m3

# Vector search (required when ENVIRONMENT=databricks)
VECTOR_SEARCH_ENDPOINT=
VECTOR_SEARCH_INDEX=deficiency_kb_index

# Data directory
DATA_DIR=

# API
API_HOST=127.0.0.1
API_PORT=8000
FRONTEND_URL=http://localhost:3000
LOG_LEVEL=INFO

# Agent tuning
MAX_CONSENSUS_ROUNDS=3
MAX_INNER_LOOPS=3
MAX_OUTER_LOOPS=1
